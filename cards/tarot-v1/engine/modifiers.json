{
  "modifiers": {
    "mod_shuffle": {
      "description": "洗牌——重置牌组，进入占卜状态",
      "effects": {
        "veil": {"type": "add", "base": 0, "random": 5},
        "trust": {"type": "add", "base": 0, "random": 3},
        "insight": {"type": "add", "base": 0, "random": 2}
      }
    },
    "mod_draw": {
      "description": "抽牌——从牌组中抽取一张",
      "effects": {
        "veil": {"type": "add", "base": 3, "random": 2},
        "cards_drawn": {"type": "add", "base": 1, "random": 0}
      }
    },
    "mod_flip": {
      "description": "翻牌——揭示一张已抽取的牌",
      "effects": {
        "veil": {"type": "add", "base": -8, "random": 6},
        "trust": {"type": "add", "base": 5, "random": 2},
        "insight": {"type": "add", "base": 3, "random": 1},
        "cards_drawn": {"type": "add", "base": -1, "random": 0},
        "cards_revealed": {"type": "add", "base": 1, "random": 0}
      }
    },
    "mod_spread_complete": {
      "description": "三牌阵完成——过去/现在/未来全部揭示",
      "effects": {
        "veil": {"type": "add", "base": -15, "random": 5},
        "insight": {"type": "add", "base": 10, "random": 5}
      }
    },
    "mod_ask": {
      "description": "提问——针对牌面提出具体问题",
      "effects": {
        "veil": {"type": "add", "base": -10, "random": 3},
        "trust": {"type": "add", "base": 3, "random": 2},
        "insight": {"type": "add", "base": 7, "random": 3}
      }
    },
    "mod_reset_reading": {
      "description": "结束本轮占卜——清理牌面",
      "effects": {
        "veil": {"type": "add", "base": 5, "random": 5},
        "trust": {"type": "add", "base": 1, "random": 2},
        "session_count": {"type": "add", "base": 1, "random": 0}
      }
    },
    "mod_all_reversed": {
      "description": "全逆位——本轮抽到的牌全部逆位，触发特殊预兆",
      "effects": {
        "veil": {"type": "add", "base": 20, "random": 5},
        "trust": {"type": "add", "base": -5, "random": 2},
        "insight": {"type": "add", "base": 15, "random": 5}
      }
    }
  }
}
